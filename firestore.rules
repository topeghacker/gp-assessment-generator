rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /questionBank/{docId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null 
        && request.resource.data.keys().hasAny(['text', 'addedAt']);
      allow delete: if request.auth != null;
    }

    match /examVersions/{docId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null 
        && request.resource.data.keys().hasAny(['version', 'createdAt']);
      allow delete: if request.auth != null;
    }

    match /standards/{docId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null 
        && request.resource.data.keys().hasAny(['code']);
      allow delete: if request.auth != null;
    }
  }
}
